# Playwright E2E mode. Loaded by `vite --mode test`. Points the app at
# the local peerjs-server spun up by `e2e/global-setup.ts`. Production
# defaults (port 443, secure: true) are preserved when this file is not
# loaded.
VITE_SIGNAL_HOST=localhost
VITE_SIGNAL_PORT=9000
VITE_SIGNAL_SECURE=false
VITE_SIGNAL_PATH=/
